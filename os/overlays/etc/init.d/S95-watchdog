#!/bin/sh
# Hardware watchdog — pet when hub health checks are added with BigFred

case "$1" in
start)
	[ -c /dev/watchdog ] || exit 0
	printf "Starting watchdog: "
	start-stop-daemon -S -b -x /usr/sbin/watchdog -- -F -f /dev/watchdog
	echo "OK"
	;;
stop)
	killall watchdog 2>/dev/null
	;;
restart)
	$0 stop
	$0 start
	;;
*)
	echo "Usage: $0 {start|stop|restart}"
	exit 1
	;;
esac
